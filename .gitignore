# Standard python ignores
*.egg-info
.coverage
.ipynb_checkpoints
**/__pycache__/
.python-version
*.pyc
**/build

# Ignore these macos generated files
.DS_Store

# Ignore these Windows generated files
*Zone.Identifier

# Ignore VS Code generated files
*.vscode

# Raw data
raw_data/
preprocessed_data/
*.csv
*.sqlite
*.zip

# Data in the package
# Add files you want to include in the git repo using `git add -f file_name`
data/

# Saved models
models/*
!models/cnn_model.keras
!models/xgb_model.pkl
!models/feature_columns.pkl
!models/class_names.json

# Global file ignores
*.joblib
*.h5
*.pickle
*.pckl
*.pkl
*.json

# Re-allow the specific model artifacts after global ignores
!models/xgb_model.pkl
!models/feature_columns.pkl
!models/class_names.json
!models/cnn_model.keras

# Credentials (or files with potentially credentials inside)
.env
.env.yaml
.credentials
secrets.toml

# Local reference notebooks (not tracked)
notebooks/kaggle_ref/
